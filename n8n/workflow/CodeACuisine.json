    {
      "parameters": {
        "jsCode": "const userCount = $node[\"[JS] Calculate Daily Quota Logic\"].json.current_count || 0;\n\nconst allRecords = $(\"[DB] Fetch Global Daily Usage\").all();\nconst globalSum = allRecords.reduce((sum, item) => {\n  return sum + (item.json.request_count || 0);\n}, 0);\n\nreturn {\n  user_count: userCount,\n  global_count: globalSum,\n  user_limit_reached: userCount >= 3,\n  global_limit_reached: globalSum >= 12\n};"
      },
