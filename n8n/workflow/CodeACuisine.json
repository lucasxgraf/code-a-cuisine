      "parameters": {
        "jsCode": "const body = $node[\"[WEB] Trigger: Recipe Generation Request\"].json.body;\nconst p = body.preferences;\nconst ing = body.ingredients;\n\nconst sortedIng = [...ing]\n  .sort((a, b) => a.name.localeCompare(b.name))\n  .map(i => `${i.name.toLowerCase()}-${i.amount}-${i.unit.toLowerCase()}`)\n  .join('|');\n\nconst config = `${p.cuisine}-${p.diet}-${p.portions}-${p.cookingTime}-${p.people}`.toLowerCase();\n\nreturn { input_hash: `${sortedIng}#${config}` };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
