    {
      "parameters": {
        "jsCode": "const body = $json.body;\n\nif (!body.ingredients || !Array.isArray(body.ingredients) || body.ingredients.length === 0) {\n  throw new Error(\"Validation Failed: No ingredients provided.\");\n}\n\nif (!body.preferences || !body.preferences.cuisine || !body.preferences.diet) {\n  throw new Error(\"Validation Failed: Preferences (cuisine/diet) are missing.\");\n}\n\nconst sanitizedIngredients = body.ingredients.map(ing => ({\n  ...ing,\n  name: ing.name.replace(/<[^>]*>?/gm, '').substring(0, 50)\n}));\n\nconst portions = parseInt(body.preferences.portions);\nif (isNaN(portions) || portions < 1 || portions > 12) {\n  throw new Error(\"Validation Failed: Portions must be between 1 and 12.\");\n}\n\nreturn {\n  ...body,\n  ingredients: sanitizedIngredients\n};"
      },
