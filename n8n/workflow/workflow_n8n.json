    {
      "parameters": {
        "jsCode": "let rawText = $node[\"[AI] Generate Recipe Collection (LLM)\"].json.output;\n\nif (rawText.includes('```json')) {\n    rawText = rawText.split('```json')[1].split('```')[0];\n} else if (rawText.includes('```')) {\n    rawText = rawText.split('```')[1].split('```')[0];\n}\n\nrawText = rawText.trim();\n\ntry {\n  const data = JSON.parse(rawText);\n  return data.recipes; \n} catch (e) {\n  throw new Error(\"JSON Parsing fehlgeschlagen: \" + e.message + \". Inhalt war: \" + rawText);\n}"
      },
