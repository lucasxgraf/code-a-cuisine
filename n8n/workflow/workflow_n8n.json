    {
      "parameters": {
        "jsCode": "const newRecipeId = $node[\"[DB] Persist Recipe Master Data\"].json.id;\nconst currentRecipe = $node[\"[LOOP] Iterate over Generated Recipes\"].json;\n\nconst preparedIngredients = currentRecipe.ingredients.map(ing => {\n  return {\n    recipe_id: newRecipeId,\n    name: ing.name,\n    amount: ing.amount,\n    unit: ing.unit,\n    is_extra: false\n  };\n});\n\nconst preparedSteps = currentRecipe.steps.map(step => {\n  return {\n    recipe_id: newRecipeId,\n    step_number: step.step_number,\n    chef_id: step.chef_id,\n    title: step.title,\n    description: step.description,\n    duration_min: step.duration_min || 0,\n    is_parallel: step.is_parallel || false\n  };\n});\n\nreturn {\n  ingredients: preparedIngredients,\n  steps: preparedSteps,\n  recipe_id: newRecipeId\n};"
      },
